{
  "schema_version": "aculeus_eval_bank.v1",
  "name": "Aculeus 10-case public-records eval bank",
  "description": "Pre-pilot regression cases for source-fed public-records investigation planning. Cases define retrieval expectations and gates, not findings.",
  "cases": [
    {
      "case_id": "eval_la_homelessness_fwa",
      "query": "LA homelessness funding oversight, contracts, subawards, and where fraud, waste, or abuse indicators could appear",
      "jurisdiction": "Los Angeles, California",
      "expected_source_families": ["USAspending", "Socrata", "ArcGIS", "public meeting records", "audits"],
      "expected_verifier_gates": ["zero_uncited_critical_claims", "candidate_only_until_receipted", "missing_records_named"]
    },
    {
      "case_id": "eval_ca_school_board_spending",
      "query": "California school board meeting packets, spending approvals, vendor contracts, amendments, and payment backup",
      "jurisdiction": "California",
      "expected_source_families": ["Socrata", "CKAN", "board agendas", "minutes", "vendor contracts"],
      "expected_verifier_gates": ["zero_uncited_critical_claims", "official_source_priority", "missing_records_named"]
    },
    {
      "case_id": "eval_sf_drug_rehab_programs",
      "query": "San Francisco drug rehabilitation program funding, nonprofit contractors, monitoring reports, and payment records",
      "jurisdiction": "San Francisco, California",
      "expected_source_families": ["Socrata", "ArcGIS", "city contracts", "audits", "IRS nonprofit records"],
      "expected_verifier_gates": ["zero_uncited_critical_claims", "candidate_only_until_receipted", "rejected_claims_separated"]
    },
    {
      "case_id": "eval_becerra_chirla_public_records",
