    },
    {
      "case_id": "eval_county_procurement_monitoring",
      "query": "County procurement monitoring for sole-source contracts, amendments, invoices, and performance reports",
      "jurisdiction": "California county government",
      "expected_source_families": ["Socrata", "CKAN", "county procurement portal", "board packets", "audits"],
      "expected_verifier_gates": ["zero_uncited_critical_claims", "official_source_priority", "candidate_only_until_receipted"]
    },
    {
      "case_id": "eval_nonprofit_pass_through_grants",
